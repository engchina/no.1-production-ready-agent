# Agent Runtime production validation env example.
# Copy values into your secret manager / GitHub Environment secrets. Do not commit real values.

# Oracle runtime store validation
AGENT_RUNTIME_ORACLE_DSN=<oracle-dsn>
AGENT_RUNTIME_ORACLE_USER=<oracle-user>
AGENT_RUNTIME_ORACLE_PASSWORD=<oracle-password>

# Deployed Agent Runtime + IdP/JWKS validation
AGENT_RUNTIME_BASE_URL=https://agent-runtime.example.com
AGENT_RBAC_JWT_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
AGENT_RBAC_JWT_SAMPLE_TOKEN=<sample-jwt>

# Optional external RBAC policy service validation
AGENT_RBAC_POLICY_URL=https://policy.example.com/agent-rbac
AGENT_RBAC_POLICY_API_KEY=<policy-api-key>

# MCP gateway OAuth/JWKS validation
AGENT_EXTERNAL_MCP_BASE_URL=https://mcp-gateway.example.com/jsonrpc
AGENT_EXTERNAL_MCP_OAUTH_TOKEN_URL=https://issuer.example.com/oauth/token
AGENT_EXTERNAL_MCP_OAUTH_CLIENT_ID=<mcp-oauth-client-id>
AGENT_EXTERNAL_MCP_OAUTH_CLIENT_SECRET=<mcp-oauth-client-secret>
AGENT_EXTERNAL_MCP_OAUTH_SCOPE=mcp.tools

# Optional MCP gateway settings
AGENT_EXTERNAL_MCP_API_KEY=<mcp-api-key>
AGENT_EXTERNAL_MCP_SESSION_ID=<mcp-session-id>

# Optional release archive / OCI Object Storage controls for wrapper/workflow
VALIDATION_ARCHIVE_ROOT=/mnt/release-record/agent-runtime
VALIDATION_OCI_UPLOAD_BUCKET_NAME=<release-record-bucket>
VALIDATION_OCI_UPLOAD_NAMESPACE=<object-storage-namespace>
VALIDATION_OCI_UPLOAD_OBJECT_PREFIX=agent-runtime/release-archives
VALIDATION_OCI_UPLOAD_EXECUTE=0
VALIDATION_OCI_RETENTION_CONFIRMED=0
