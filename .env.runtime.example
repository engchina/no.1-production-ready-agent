# Control Plane MCP token 派生用 master secret。32 bytes 以上のランダム値を設定する。
AGENT_CONTROL_PLANE_MCP_TOKEN_SECRET=

# 外部 dispatcher を使う場合だけ external にし、Oracle checkpoint を必須設定する。
AGENT_RUNTIME_DISPATCH_MODE=in_process
AGENT_RUNTIME_REPOSITORY_BACKEND=memory
AGENT_RUNTIME_ORACLE_DSN=
AGENT_RUNTIME_ORACLE_USER=
AGENT_RUNTIME_ORACLE_PASSWORD=

# Runtime API 認証。値は RuntimeDefinition には保存せず env 名だけを参照する。
OPENCLAW_GATEWAY_TOKEN=
HERMES_API_SERVER_KEY=
DEER_FLOW_INTERNAL_AUTH_TOKEN=
